# Para Atlas o mongo local. Si USE_MEMORY_DB=true, esta URI se ignora.
MONGODB_URI=mongodb+srv://usuario:password@cluster.mongodb.net/canvet?retryWrites=true&w=majority
JWT_SECRET=canvet_secret_key_2026
PORT=5000
NODE_ENV=development

# Modo desarrollo sin instalar mongo: arranca mongodb-memory-server y siembra automáticamente.
# Datos efímeros (se reinicializan en cada arranque del server).
USE_MEMORY_DB=true
